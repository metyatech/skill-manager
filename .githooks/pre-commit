#!/bin/sh

# Run verification (lint + format + agents.md)
if [ -f package.json ]; then
  # We use --ignore-scripts or similar if we don't want to run verify during pre-commit?
  # No, the rule says run the full verification suite.
  # But we want to auto-update AGENTS.md after verify.
  npm run verify
  
  # Auto-update AGENTS.md and add to commit
  if command -v compose-agentsmd > /dev/null 2>&1; then
    compose-agentsmd --compose || true
    git add AGENTS.md || true
  fi
fi
